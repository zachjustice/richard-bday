<tr class="border-b border-ink/5 hover:bg-ink/5 transition-colors">
  <!-- Time -->
  <td class="py-3 px-2 text-xs text-ink/60 whitespace-nowrap">
    <%= relative_time_with_tooltip(event.event_time_at) %>
  </td>

  <!-- Game -->
  <td class="py-3 px-2 text-xs text-ink/60">
    <% if event.game_id %>
      <span class="font-mono">#<%= event.game_id %></span>
    <% else %>
      <span class="text-ink/40">Room</span>
    <% end %>
  </td>

  <!-- Type Badge -->
  <td class="py-3 px-2">
    <span class="inline-block px-2 py-1 rounded-lg text-xs font-bold <%= event_type_badge_class(event.event_type) %>">
      <%= event.event_type.humanize %>
    </span>
  </td>

  <!-- Actor -->
  <td class="py-3 px-2 text-sm">
    <% if event.system_event? %>
      <span class="text-ink/50">System</span>
    <% else %>
      <span class="font-medium text-ink"><%= event.actor_display_name %></span>
    <% end %>
  </td>

  <!-- Description -->
  <td class="py-3 px-2 text-sm text-ink/70">
    <%= render_event_description(event) %>
  </td>

  <!-- Metadata -->
  <td class="py-3 px-2">
    <% if event.metadata.present? && event.metadata.keys.any? %>
      <details>
        <summary class="text-xs text-ink/40 cursor-pointer hover:text-ink/60 whitespace-nowrap">View</summary>
        <pre class="text-xs text-ink/50 mt-1 p-2 bg-ink/5 rounded-lg overflow-x-auto max-w-xs"><%= h(JSON.pretty_generate(event.metadata)) %></pre>
      </details>
    <% else %>
      <span class="text-xs text-ink/30">-</span>
    <% end %>
  </td>
</tr>
