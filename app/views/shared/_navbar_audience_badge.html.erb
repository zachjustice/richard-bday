<span id="navbar-audience-count"
      class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold
             bg-accent-orange/15 text-ink/70 transition-opacity duration-200
             <%= 'hidden' if !audience_count || audience_count.to_i.zero? %>"
      aria-live="polite" aria-atomic="true">
  <%= audience_count %> watching
</span>
