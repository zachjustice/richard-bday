<%# Decorative SVG doodles — hand-drawn background motifs, rendered behind cards. %>
<%# Applied globally via app/views/layouts/application.html.erb + discord_activity.html.erb. %>
<div class="fixed inset-0 z-avatars pointer-events-none overflow-hidden" aria-hidden="true">
  <!-- Star burst -->
  <svg class="doodle-decoration absolute top-[10%] left-[5%] w-12 h-12 rotate-12" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
    <path d="M24 4v8M24 36v8M4 24h8M36 24h8M10 10l6 6M32 32l6 6M10 38l6-6M32 16l6-6" class="text-accent-tertiary"/>
  </svg>

  <!-- Squiggle line -->
  <svg class="doodle-decoration absolute top-[20%] right-[8%] w-16 h-8 -rotate-6" viewBox="0 0 64 32" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
    <path d="M4 16c8-12 16 12 24 0s16 12 24 0" class="text-accent-primary"/>
  </svg>

  <!-- Circle with dots -->
  <svg class="doodle-decoration absolute bottom-[25%] left-[8%] w-14 h-14 rotate-[-15deg]" viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
    <circle cx="28" cy="28" r="20" stroke-dasharray="8 6" class="text-accent-secondary"/>
    <circle cx="28" cy="28" r="4" fill="currentColor" class="text-accent-secondary"/>
  </svg>

  <!-- Arrow -->
  <svg class="doodle-decoration absolute top-[45%] right-[6%] w-10 h-10 rotate-12" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M8 32C14 24 22 18 32 8M24 6l10 2-2 10" class="text-accent-tertiary"/>
  </svg>

  <!-- X mark -->
  <svg class="doodle-decoration absolute bottom-[35%] right-[12%] w-10 h-10 rotate-6" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
    <path d="M10 10l20 20M30 10l-20 20" class="text-accent-primary"/>
  </svg>

  <!-- Underline scribble (single, dedup of two near-duplicates) -->
  <svg class="doodle-decoration absolute top-[65%] left-[12%] w-20 h-6 rotate-[-8deg]" viewBox="0 0 80 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
    <path d="M4 12c12-6 24 6 36 0s24 6 36 0" class="text-accent-secondary"/>
  </svg>

  <!-- Small 5-point star -->
  <svg class="doodle-decoration absolute top-[75%] right-[20%] w-8 h-8 -rotate-12" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M16 4l3 9h9l-7 5 3 9-8-6-8 6 3-9-7-5h9z" class="text-accent-tertiary"/>
  </svg>

  <!-- Pencil - drawing diagonally -->
  <svg class="doodle-decoration absolute top-[8%] right-[30%] w-16 h-16 rotate-[-25deg]" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 52L52 12" class="text-accent-tertiary"/>
    <path d="M48 8l8 8-4 4-8-8z" class="text-accent-primary"/>
    <path d="M8 56l4-8 8 8-8 4z" class="text-accent-tertiary"/>
    <line x1="16" y1="48" x2="44" y2="20" class="text-ink/30"/>
  </svg>

  <!-- Loop-de-loop swirl -->
  <svg class="doodle-decoration absolute top-[35%] left-[35%] w-20 h-12 rotate-6" viewBox="0 0 80 48" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
    <path d="M4 24c8-16 16 0 24-16s16 16 24 0s16 16 24-8" class="text-accent-secondary"/>
  </svg>

  <!-- 4-point sparkle star cluster -->
  <svg class="doodle-decoration absolute bottom-[10%] left-[3%] w-14 h-14" viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
    <path d="M28 8v12M28 36v12M8 28h12M36 28h12" class="text-accent-tertiary"/>
    <path d="M16 16l8 8M32 32l8 8M16 40l8-8M32 24l8-8" class="text-accent-tertiary"/>
    <path d="M44 12v6M44 6v2M38 9h6M46 9h4" class="text-accent-primary"/>
  </svg>

  <!-- Spiral/notebook binding - left edge -->
  <svg class="doodle-decoration absolute top-[40%] left-[1%] w-6 h-32" viewBox="0 0 24 128" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
    <circle cx="12" cy="16" r="6" class="text-ink/20"/>
    <circle cx="12" cy="40" r="6" class="text-ink/20"/>
    <circle cx="12" cy="64" r="6" class="text-ink/20"/>
    <circle cx="12" cy="88" r="6" class="text-ink/20"/>
    <circle cx="12" cy="112" r="6" class="text-ink/20"/>
  </svg>

  <!-- Sparkle dots scattered -->
  <svg class="doodle-decoration absolute top-[30%] right-[35%] w-8 h-8" viewBox="0 0 32 32" fill="currentColor">
    <circle cx="8" cy="8" r="2" class="text-accent-tertiary"/>
    <circle cx="24" cy="12" r="1.5" class="text-accent-primary"/>
    <circle cx="16" cy="24" r="2" class="text-accent-secondary"/>
  </svg>

  <!-- Curly bracket / brace -->
  <svg class="doodle-decoration absolute top-[55%] right-[3%] w-8 h-20 rotate-12" viewBox="0 0 32 80" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
    <path d="M24 4c-12 0-12 16-12 32s0 32 12 32" class="text-accent-tertiary"/>
  </svg>

  <!-- Small loop doodle - bottom center -->
  <svg class="doodle-decoration absolute bottom-[5%] left-[42%] w-12 h-8" viewBox="0 0 48 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
    <path d="M4 24c8-24 16 0 20-16s12 24 20 0" class="text-accent-primary"/>
  </svg>
</div>
